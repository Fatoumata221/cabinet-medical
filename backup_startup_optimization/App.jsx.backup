            <Layout>
              <MesPatientsPage />
            </Layout>
          </ProtectedRoute>
        } />
        
        <Route path="/medical-records" element={
          <ProtectedRoute allowedRoles={['doctor']}>
            <Layout>
              <MedicalRecordsPage />
            </Layout>
          </ProtectedRoute>
        } />
        
        <Route path="/prescriptions" element={
          <ProtectedRoute allowedRoles={['doctor']}>
            <Layout>
              <PrescriptionsPage />
            </Layout>
          </ProtectedRoute>
        } />

        {/* Routes pour médecins et secrétaires - Ma File d'attente */}
        <Route path="/my-waiting-queue" element={
          <ProtectedRoute allowedRoles={['doctor']}>
            <Layout>
              <MyWaitingQueuePage />
            </Layout>
          </ProtectedRoute>
        } />
        
        <Route path="/doctor-dashboard" element={
          <ProtectedRoute allowedRoles={['doctor']}>
            <Layout>
              <DoctorDashboard />
            </Layout>
          </ProtectedRoute>
        } />



        {/* Routes pour médecins et secrétaires - Autres pages */}
        <Route path="/introduction-patient" element={
          <ProtectedRoute allowedRoles={['secretary']}>
            <Layout>
              <IntroductionPatientPage />
            </Layout>
          </ProtectedRoute>
        } />
        
        <Route path="/fiche-identification" element={
          <ProtectedRoute allowedRoles={['secretary']}>
            <Layout>
              <FicheIdentificationPage />
            </Layout>
          </ProtectedRoute>
        } />
        
        <Route path="/examen-medical" element={
          <ProtectedRoute allowedRoles={['doctor']}>
            <Layout>
              <ExamenMedicalPage />
            </Layout>
          </ProtectedRoute>
        } />
        
        <Route path="/prescription" element={
          <ProtectedRoute allowedRoles={['doctor']}>
            <Layout>
              <PrescriptionPage />
            </Layout>
          </ProtectedRoute>
        } />
        
        <Route path="/actes" element={
          <ProtectedRoute allowedRoles={['doctor']}>
            <Layout>
              <ActesConsultationPage />
            </Layout>
          </ProtectedRoute>
        } />
        
        <Route path="/bcds" element={
          <ProtectedRoute allowedRoles={['doctor']}>
            <Layout>
              <BcdsPage />
            </Layout>
          </ProtectedRoute>
        } />
        
        <Route path="/statistics" element={
          <ProtectedRoute allowedRoles={['admin']}>
            <Layout>
              <StatisticsPage />
            </Layout>
          </ProtectedRoute>
        } />

        {/* Routes pour médecins et secrétaires - Consultation */}
        <Route path="/consultations" element={
          <ProtectedRoute allowedRoles={['doctor']}>
            <Layout>
              <ConsultationsPage />
            </Layout>
          </ProtectedRoute>
        } />

        {/* Routes pour médecins et secrétaires - Facturation */}
        <Route path="/facturation/actes" element={
          <ProtectedRoute allowedRoles={['secretary']}>
            <Layout>
              <ActesFacturationPage />
            </Layout>
          </ProtectedRoute>
        } />

        <Route path="/facturation/examens" element={
          <ProtectedRoute allowedRoles={['secretary']}>
            <Layout>
              <ExamensFacturationPage />
            </Layout>
          </ProtectedRoute>
        } />

        <Route path="/facturation/factures" element={
          <ProtectedRoute allowedRoles={['secretary']}>
            <Layout>
              <FacturesFacturationPage />
            </Layout>
          </ProtectedRoute>
        } />

        <Route path="/facturation/labo" element={
          <ProtectedRoute allowedRoles={['secretary']}>
            <Layout>
              <LaboFacturationPage />
            </Layout>
          </ProtectedRoute>
        } />

        <Route path="/facturation/pharmacie" element={
          <ProtectedRoute allowedRoles={['secretary']}>
            <Layout>
              <PharmacieFacturationPage />
            </Layout>
          </ProtectedRoute>
        } />

        <Route path="/facturation/divers" element={
          <ProtectedRoute allowedRoles={['secretary']}>
            <Layout>
              <DiversPage />
            </Layout>
          </ProtectedRoute>
        } />

        {/* Routes pour médecins et secrétaires - Reporting */}
        <Route path="/reporting" element={
          <ProtectedRoute allowedRoles={['admin']}>
            <Layout>
              <ReportingPage />
            </Layout>
          </ProtectedRoute>
        } />

        {/* Routes pour médecins et secrétaires - Historiques & Archives */}
        <Route path="/historiques-archives" element={
          <ProtectedRoute allowedRoles={['admin']}>
            <Layout>
              <HistoriquesArchivesPage />
            </Layout>
          </ProtectedRoute>
        } />
        
        {/* Routes admin */}
        <Route path="/users" element={
          <ProtectedRoute allowedRoles={['admin']}>
            <Layout>
              <UsersPage />
            </Layout>
          </ProtectedRoute>
        } />
        
        <Route path="/cabinet-settings" element={
          <ProtectedRoute allowedRoles={['admin']}>
            <Layout>
              <CabinetSettingsPage />
            </Layout>
          </ProtectedRoute>
        } />
        
        <Route path="/security" element={
          <ProtectedRoute allowedRoles={[ROLES.ADMIN]}>
            <Layout>
              <SecurityPage />
            </Layout>
          </ProtectedRoute>
        } />
        
        {/* Route de test des permissions (développement uniquement) */}
        <Route path="/test-permissions" element={
          <ProtectedRoute>
            <Layout>
              <PermissionTestPage />
            </Layout>
          </ProtectedRoute>
        } />

        {/* Route par défaut */}
        <Route path="*" element={<Navigate to="/dashboard" replace />} />
      </Routes>
    </Router>
  );
};

const App = () => {
  return (
    <AuthProvider>
      <div className="App">
        <NotificationManager />
        <AppContent />
      </div>
    </AuthProvider>
  );
};

export default App;
