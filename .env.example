# Configuration Supabase
# Copiez ce fichier vers .env et remplissez avec vos vraies valeurs

# URL de votre projet Supabase
VITE_SUPABASE_URL=https://votre-projet.supabase.co

# Clé publique anonyme de votre projet Supabase
VITE_SUPABASE_ANON_KEY=votre-cle-anon-key-ici

# Clé de service pour l'API admin (nécessaire pour la réinitialisation de mot de passe)
# ⚠️ ATTENTION: Cette clé est très sensible - utilisez uniquement en développement local
VITE_SUPABASE_SERVICE_KEY=votre-service-role-key-ici

# Exemple avec des valeurs fictives (à remplacer) :
# VITE_SUPABASE_URL=https://abcdefghijklmnop.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# VITE_SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
 